# Development image: source is bind-mounted at runtime; node_modules live in a named volume.
FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

ENV NEXT_TELEMETRY_DISABLED=1
EXPOSE 2750

# Install deps and start dev server (Turbopack). Mount `.:/app` and a volume on `node_modules`.
CMD ["sh", "-c", "npm ci && npm run dev -- --port 2750 --hostname 0.0.0.0"]
